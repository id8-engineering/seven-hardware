	(text_box "BZ1 - Buzzer\nMagnetic transducer that converts the electrical signal into sound.\n\nQ1 - NPN Transistor (MMST3904)\nActs as a low-side switch to drive the buzzer current.\n\nR3 - Base Resistor\nLimits current from the control signal into the transistor base.\n\nD1 - Schottky Diode (BAT54)\nFlyback diode protecting the transistor from voltage spikes."
		(exclude_from_sim no)
		(at 176.53 85.09 0)
		(size 107.95 80.01)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type dash)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 2.54 2.54)
			)
			(justify left top)
		)
		(uuid "1c53b560-4223-4e25-9019-000f9a441119")
	)
	(text_box "User controlled buzzer"
		(exclude_from_sim no)
		(at 176.53 12.7 0)
		(size 40.64 11.43)
		(margins 0.9525 0.9525 0.9525 0.9525)
