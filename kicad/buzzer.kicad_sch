				(thickness 0.508)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "45b6c1e0-acb9-4b33-ba79-74506cb7727e")
	)
	(text_box "Transistor-driven buzzer driver controlled by a digital signal called BUZZER. The purpose is to allow a low-current logic output (such as from a microcontroller) to drive a magnetic buzzer/transducer that requires higher current and a 5 V supply."
		(exclude_from_sim no)
		(at 176.53 24.13 0)
		(size 107.95 53.34)
		(margins 0.9525 0.9525 0.9525 0.9525)
