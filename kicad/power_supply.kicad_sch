	(text_box "U5 - ISL85410FRZ-T7A\n\nSynchronous buck (step-down) switching regulator\n\nInput voltage range: 3 V - 40 V\n\nOutput current: up to 1 A\n\nIntegrated high-side and low-side NMOS switches\n\nAdjustable switching frequency: 300 kHz - 2 MHz (500 kHz default)\n\nSupports PFM or forced PWM operation\n\nAdjustable output voltage via feedback pin"
		(exclude_from_sim no)
		(at 176.53 85.09 0)
		(size 107.95 80.01)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type dash)
		)
		(fill
			(type none)
		)
		(effects
