				(size 2.54 2.54)
			)
			(justify left top)
		)
		(uuid "230c951d-1f24-45bf-bb28-cfd8f9094090")
	)
	(text_box "This circuit implements a buck (step-down) switching regulator that converts an input voltage in the 6-40 V range to a regulated 5 V output supply for the system."
		(exclude_from_sim no)
		(at 176.53 24.13 0)
